{
  "name": "panindigan-official",
  "version": "0.1.7",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "description": "Panindigan Official — Enterprise-grade, modular, all-in-one Discord bot.",
  "author": "Panindigan Official",
  "license": "MIT",
  "keywords": [
    "discord-bot",
    "panindigan",
    "enterprise"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\""
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "chalk": "^5.6.2",
    "discord.js": "^14.27.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "lavalink-client": "^2.10.3",
    "mongoose": "^8.24.1",
    "ms": "^2.1.3",
    "node-cron": "^3.0.3",
    "openai": "^4.104.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.20.1",
    "@types/node-cron": "^3.0.11",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.15.0"
  },
  "packageManager": "pnpm@11.15.0"
}
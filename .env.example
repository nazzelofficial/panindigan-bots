# ==========================================================================
# Panindigan Official — Environment Variables (SENSITIVE)
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Non-sensitive bot configuration (prefix, colors, tier pricing, etc.) lives
# in `config.json` instead — see that file for anything that isn't a secret.
# ==========================================================================

# --- Discord ------------------------------------------------------------
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Database (MongoDB Atlas) --------------------------------------------
MONGODB_URI=

# --- Lavalink (music) -----------------------------------------------------
# You can define ONE node with these three vars, or define many nodes in
# config.json > lavalink.nodes (each node can also pull its secret fields
# from env, see config.json comments).
LAVALINK_HOST=
LAVALINK_PORT=
LAVALINK_PASSWORD=
LAVALINK_SECURE=false

# --- AI (OpenAI) ------------------------------------------------------------
OPENAI_API_KEY=

# --- REST API / Dashboard -------------------------------------------------
API_PORT=3001
API_JWT_SECRET=
SESSION_SECRET=

# --- Owner / Access control ------------------------------------------------
# Comma-separated Discord user IDs that always have Owner-level access,
# regardless of what's stored in the database.
BOT_OWNER_IDS=

# --- Misc -------------------------------------------------------------------
NODE_ENV=development
